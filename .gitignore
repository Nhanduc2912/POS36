# ==================================
# ROOT .gitignore FOR POS36 PROJECT
# ==================================

# 1. Biến môi trường và Bảo mật (Environment & Secrets)
# Tuyệt đối không push file chứa khóa bí mật
.env
.env.local
.env.development
.env.test
.env.production
# CHO PHÉP push file mẫu
!.env.example

# 2. Thư mục build tự động & Logs (Từ file .bat)
publish/
logs/
*.log

# 3. .NET (Backend API)
# Bỏ qua tất cả các thư mục biên dịch của C# chuẩn
**/[Bb]in/
**/[Oo]bj/
# Các file tạm của Visual Studio
*.user
*.userosscache
*.sln.docstates
# File cấu hình nội bộ (nếu có dev riêng)
# appsettings.Development.json (Cân nhắc bỏ comment nếu không muốn push)

# 4. Node.js (Frontend Web)
**/node_modules/
**/dist/
**/dist-ssr/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 5. IDEs, Hệ điều hành (Môi trường code)
.vs/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sqlite3

# Cấu hình cá nhân VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# 6. File rác hoặc backup
*.bak
*.tmp
*.swp
