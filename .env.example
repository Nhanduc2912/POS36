# ============================================
# POS36 - Environment Configuration Example
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Database Connection
DB_SERVER=localhost
DB_NAME=POS36_Db
DB_USER=sa
DB_PASSWORD=YourStrongPassword123!

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-at-least-32-characters-long-for-security
JWT_ISSUER=POS36Api
JWT_AUDIENCE=POS36Client
JWT_EXPIRATION_MINUTES=1440

# Google Gemini AI
GEMINI_API_KEY=your-google-gemini-api-key-here

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Base URL
VITE_API_URL=http://localhost:5198/api

# SignalR Hub URL
VITE_SIGNALR_URL=http://localhost:5198/kitchenHub

# EmailJS Configuration (for OTP)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ============================================
# DOCKER CONFIGURATION
# ============================================

# SQL Server Password (for Docker)
DOCKER_SA_PASSWORD=Pos36_Secret_Password_123!

# Backend Port
DOCKER_BACKEND_PORT=5098

# Frontend Port
DOCKER_FRONTEND_PORT=3000

# Database Port
DOCKER_DB_PORT=1433

# ============================================
# PRODUCTION CONFIGURATION
# ============================================

# Production API URL
PROD_API_URL=https://api.pos36.com

# Production Frontend URL
PROD_FRONTEND_URL=https://pos36.com

# Production Database
PROD_DB_SERVER=your-production-db-server
PROD_DB_NAME=POS36_Prod
PROD_DB_USER=pos36_user
PROD_DB_PASSWORD=your-production-db-password

# ============================================
# OPTIONAL SERVICES
# ============================================

# Bank Webhook URL (for payment notifications)
BANK_WEBHOOK_URL=https://your-domain.com/api/webhook/bank

# Ngrok Tunnel (for development)
NGROK_AUTH_TOKEN=your-ngrok-auth-token

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# Application Insights (Azure)
APPINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key
